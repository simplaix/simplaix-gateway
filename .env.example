# Simplaix Gateway Configuration
# Copy this file to .env and update values

# ====================
# Gateway JWT Configuration (verification only)
# ====================
# Shared secret for verifying JWTs signed by gateway-app (must match gateway-app's JWT_SECRET)
JWT_SECRET=your-super-secret-key-change-in-production

# For asymmetric key (RSA/EC) - use PEM format
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# JWT issuer claim (must match gateway-app's JWT_ISSUER)
JWT_ISSUER=simplaix-gateway

# Optional: JWT audience claim
JWT_AUDIENCE=simplaix-gateway

# ====================
# External JWT Issuers (for Agent Consumers)
# ====================
# JSON array of external issuers that can authenticate against the gateway
#
# Example with shared secret:
# JWT_EXTERNAL_ISSUERS='[{"issuer":"https://auth.mycompany.com","secret":"shared-secret","audience":"simplaix-gateway"}]'
#
# Example with Azure AD / OIDC:
# JWT_EXTERNAL_ISSUERS='[{"issuer":"https://login.microsoftonline.com/TENANT_ID/v2.0","jwksUri":"https://login.microsoftonline.com/TENANT_ID/discovery/v2.0/keys","audience":"api://simplaix-gateway"}]'
#
JWT_EXTERNAL_ISSUERS=

# ====================
# Initial Admin User
# ====================
# Credentials for creating the initial admin user on first startup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# ====================
# MCP Server
# ====================
MCP_SERVER_URL=http://localhost:3001

# ====================
# Database Configuration (PostgreSQL)
# ====================
DATABASE_URL=postgresql://gateway:gateway@localhost:5432/gateway

# ====================
# Docker Compose Settings
# ====================
# Override PostgreSQL credentials (used by docker-compose.yml)
# POSTGRES_USER=gateway
# POSTGRES_PASSWORD=gateway
# POSTGRES_DB=gateway
# POSTGRES_PORT=5432

# Gateway port
PORT=3001

# ====================
# Public URL (for pairing links)
# ====================
# Set this to make pairing links clickable in WhatsApp/Telegram.
# Use scripts/dev-tunnel.sh to auto-populate via Cloudflare quick tunnel.
# Falls back to http://localhost:$PORT if unset.
# GATEWAY_PUBLIC_URL=https://xxx.trycloudflare.com

# ====================
# Gateway API Keys (for server-to-server trust)
# ====================
# API keys are managed via the admin API:
#   POST /api/v1/admin/api-keys   — create a new key (returns gk_xxx, shown once)
#   GET  /api/v1/admin/api-keys   — list existing keys
#   DELETE /api/v1/admin/api-keys/:id — revoke a key
#
# Usage: Include X-Api-Key header in requests from trusted services (e.g., Python agents).
# Two auth modes supported:
#   1. X-Api-Key: gk_xxx + Authorization: Bearer <jwt>  (full user context)
#   2. X-Api-Key: gk_xxx + X-User-Id: user_123          (lightweight, for agents)
#
# Scopes: credentials:resolve (default), credentials:read, credentials:write
