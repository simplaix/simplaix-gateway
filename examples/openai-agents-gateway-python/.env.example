# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Gateway
GATEWAY_API_URL=http://localhost:3001

# Agent runtime token from: POST /api/v1/admin/agents
AGENT_RUNTIME_TOKEN=art_xxx
# Optional: comma-separated provider IDs. Empty means unified mode.
GATEWAY_PROVIDER_IDS=

# For invoke_via_gateway.py
GATEWAY_AGENT_ID=your-agent-id
# Option 1: provide a pre-made JWT directly
GATEWAY_USER_JWT=
# Option 2: auto-generate a test JWT (must match gateway's JWT_EXTERNAL_ISSUERS config)
CLIENT_JWT_SECRET=your-shared-client-secret
CLIENT_JWT_ISSUER=https://my-client-app.example.com
USER_MESSAGE=Please use MCP tools and summarize.
