# ============================================
# Gateway App Configuration (Next.js Frontend)
# ============================================
# This file is for the gateway-app (Next.js frontend).
# For the gateway backend config, see /.env.example in the root.

# OpenAI API Key (required for the CopilotKit agent)
OPENAI_API_KEY=sk-xxx

# ============================================
# JWT Configuration (must match gateway core)
# ============================================
# Shared secret for signing JWTs — must be the same value as the gateway core's JWT_SECRET
JWT_SECRET=your-super-secret-key-change-in-production

# JWT issuer claim — must match the gateway core's JWT_ISSUER
JWT_ISSUER=simplaix-gateway

# Token expiration time (e.g., "24h", "7d", "1h")
JWT_EXPIRES_IN=24h

# ============================================
# Gateway API Connection
# ============================================
# URL of the gateway backend
GATEWAY_API_URL=http://localhost:3000

# (OPTIONAL) Fallback JWT Token for server-side API proxy
# 
# The standard auth flow sends the user's JWT via the Authorization header.
# This env var is only needed as a fallback for:
# - Development without user login
# - Automated/CI testing
#
# Leave empty to require user login for all operations.
GATEWAY_JWT_TOKEN=

# ============================================
# Strands Agent Configuration
# ============================================
# URL where CopilotKit connects to the Python agent
STRANDS_AGENT_URL=http://localhost:8000

# Agent server settings (optional)
AGENT_PORT=8000
AGENT_PATH=/
