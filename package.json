{
  "name": "simplaix-gateway",
  "version": "0.1.0",
  "description": "MCP Gateway with identity, confirmation, and audit capabilities",
  "type": "module",
  "scripts": {
    "dev": "vc dev",
    "dev:server": "tsx watch --env-file=.env src/server.ts",
    "build": "vc build",
    "deploy": "vc deploy",
    "typecheck:gateway": "tsc -p tsconfig.gateway.json --noEmit",
    "test:gateway": "tsx --test test/**/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/mcp": "0.2.3",
    "@hono/node-server": "^1.19.9",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "bcryptjs": "^3.0.3",
    "cloudflared": "^0.7.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.7",
    "jose": "^5.2.0",
    "nanoid": "^5.1.6",
    "postgres": "^3.4.8",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.11.17",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
